{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentSoul v2",
  "version": "2.0.0-alpha.0",
  "identifier": "com.agentsoul.desktop.v2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run typecheck",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "desktop-companion",
        "title": "AgentSoul Desktop Companion",
        "url": "index.html",
        "width": 260,
        "height": 260,
        "minWidth": 240,
        "minHeight": 240,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "resizable": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "desktop-companion-drag",
          "description": "Allow the frameless desktop companion window to be dragged by the pet surface.",
          "windows": ["desktop-companion"],
          "permissions": ["core:window:allow-start-dragging"]
        }
      ],
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DOWNLOAD/*.codex-pet/**",
          "$HOME/Downloads/*.codex-pet/**",
          "/Users/ldh/Downloads/*.codex-pet/**",
          "$APPDATA/agentsoul/desktop-v2/pets/*.codex-pet/**",
          "$APPDATA/agentsoul/desktop-v2/pets/current.codex-pet/**",
          "../data/desktop-v2/pets/*.codex-pet/**",
          "../data/desktop-v2/pets/current.codex-pet/**"
        ]
      }
    }
  }
}
