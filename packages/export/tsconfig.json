{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@agentsoul/export": ["src/index.ts"],
      "@agentsoul/companion": ["../companion/src/index.ts"],
      "@agentsoul/domain": ["../domain/src/index.ts"],
      "@agentsoul/persistence": ["../persistence/src/index.ts"],
      "@agentsoul/provider": ["../provider/src/index.ts"]
    }
  },
  "include": ["src", "tests"]
}
