{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@agentsoul/mcp-adapter": ["src/index.ts"],
      "@agentsoul/domain": ["../domain/src/index.ts"],
      "@agentsoul/runtime": ["../runtime/src/index.ts"],
      "@agentsoul/safety": ["../safety/src/index.ts"]
    }
  },
  "include": ["src", "tests"]
}
