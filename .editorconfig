# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,yml,yaml}]
indent_size = 2

[*.{md,markdown}]
indent_size = 2
max_line_length = 100
trim_trailing_whitespace = false

[*.{ts,tsx,js,jsx}]
indent_size = 2

[*.html]
indent_size = 2

[*.css]
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_size = 4

[*.bat]
indent_size = 4
end_of_line = crlf

[*.{diff,patch}]
trim_trailing_whitespace = false

[.gitattributes]
indent_size = 2

[.gitignore]
indent_size = 2
